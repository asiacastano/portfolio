---
const { variant = "light" } = Astro.props;

const textColor = variant === "dark" ? "text-[#113857]" : "text-white";
---

<nav class="absolute left-0 top-0 z-30 w-full">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-6 md:px-12 md:py-10">
    <a
      href="/"
      class={`font-title text-xl leading-none tracking-[0.02em] ${textColor} md:text-[1.5rem]`}
    >
      ASIA CASTANO
    </a>

    <!-- Desktop menu -->
    <div class="hidden items-center gap-8 md:flex md:gap-12">
      <a
        href="/projects"
        class={`font-title inline-flex items-center text-xl leading-none tracking-[0.02em] ${textColor} transition hover:opacity-70 md:text-[1.5rem]`}
      >
        PROJECTS
      </a>

      <a
        href="mailto:asia.castano@hotmail.com"
        class={`font-title inline-flex items-center text-xl leading-none tracking-[0.02em] ${textColor} transition hover:opacity-70 md:text-[1.5rem]`}
      >
        CONTACT ME
      </a>

      <a
        href="https://www.linkedin.com/in/asiacastano/"
        target="_blank"
        rel="noopener noreferrer"
        class={`inline-flex items-center leading-none ${textColor} transition hover:opacity-70`}
        aria-label="LinkedIn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 448 512"
          fill="currentColor"
          class="relative top-[-2px] h-6 w-6 md:h-7 md:w-7"
        >
          <path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.3 0-55.7 37.7-55.7 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.7-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z" />
        </svg>
      </a>
    </div>

    <!-- Mobile burger button -->
    <button
      id="mobile-menu-button"
      class={`flex items-center md:hidden ${textColor}`}
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <svg
        id="menu-open-icon"
        xmlns="http://www.w3.org/2000/svg"
        class="h-7 w-7"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>

      <svg
        id="menu-close-icon"
        xmlns="http://www.w3.org/2000/svg"
        class="hidden h-7 w-7"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6l-12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="hidden md:hidden"
  >
    <div class="mx-6 mt-2 flex flex-col gap-5 rounded-2xl bg-black/20 px-6 py-6 backdrop-blur-md">
      <a
        href="/projects"
        class={`font-title text-lg leading-none tracking-[0.02em] ${textColor} transition hover:opacity-70`}
      >
        PROJECTS
      </a>

      <a
        href="mailto:asia.castano@hotmail.com"
        class={`font-title text-lg leading-none tracking-[0.02em] ${textColor} transition hover:opacity-70`}
      >
        CONTACT ME
      </a>

      <a
        href="https://www.linkedin.com/in/asiacastano/"
        target="_blank"
        rel="noopener noreferrer"
        class={`font-title text-lg leading-none tracking-[0.02em] ${textColor} transition hover:opacity-70`}
      >
        LINKEDIN
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  button?.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');

    menu.classList.toggle('hidden');
    openIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
    button.setAttribute('aria-expanded', String(!isOpen));
  });
</script>