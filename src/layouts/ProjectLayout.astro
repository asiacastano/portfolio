---
import Layout from "./Layout.astro";
import Footer from "../components/Footer.astro";

const {
  title,
  subtitle = "",
  category,
  year,
  summary,
  heroImage,
  description = "",
  canonical = "",
} = Astro.props;
---




<Layout title={title} description={description} canonical={canonical} navVariant="dark">


  <!-- HERO -->
  <section class="mx-auto max-w-7xl px-6 pb-12 pt-28 md:px-12 md:pb-16 md:pt-36">
  <a
  href="/projects"
  class="group inline-flex items-center text-sm font-medium text-[#113857]/80 transition duration-300 hover:text-[#113857]"
>
  <span class="mr-2 transition-transform duration-300 group-hover:-translate-x-1">
    ←
  </span>
  Back to projects
</a>
    <div class="grid gap-10 md:grid-cols-[1fr_1fr] md:items-end">
      <div>
        <p class="text-[11px] uppercase tracking-[0.2em] text-[#113857]/55">
          {category}
        </p>

        <h1 class="mt-4 font-title text-[52px] leading-[0.9] tracking-[0.02em] text-[#113857] md:text-[90px]">
          {title}
        </h1>

        {subtitle && (
          <p class="mt-4 max-w-2xl font-hand text-[28px] leading-[1.1] text-[#113857] md:text-[40px]">
            {subtitle}
          </p>
        )}
      </div>

      <div>
        <p class="max-w-md text-sm leading-7 text-[#4a4a4a] md:text-base md:leading-8">
          {summary}
        </p>
      </div>
    </div>
  </section>

  <!-- HERO IMAGE -->
  <section class="mx-auto max-w-7xl px-6 pb-16 md:px-12 md:pb-24">
    <div class="relative overflow-hidden rounded-[2rem] shadow-[0_14px_35px_rgba(0,0,0,0.08)]">
      <img
        src={heroImage}
        alt={title}
        class="h-[320px] w-full object-cover md:h-[560px]"
      />
    </div>
  </section>

  <!-- MAIN CONTENT -->
 <section class="mx-auto max-w-7xl px-6 pb-16 md:px-12 md:pb-24">
  <div class="space-y-24">
    <slot />
  </div>
</section>

  <!-- GALLERY -->
  <section class="mx-auto max-w-7xl px-6 pb-16 md:px-12 md:pb-24">
    <slot name="gallery" />
  </section>

  <!-- BACK -->
  <section class="mx-auto max-w-7xl px-6 pb-16 md:px-12 md:pb-24">
   <a
  href="/projects"
  class="group inline-flex items-center text-sm font-medium text-[#113857]/80 transition duration-300 hover:text-[#113857]"
>
  <span class="mr-2 transition-transform duration-300 group-hover:-translate-x-1">
    ←
  </span>
  Back to projects
</a>
  </section>

  <Footer />
</Layout>