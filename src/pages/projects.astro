---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/projects.js";



<Layout
  title="Projects – Asia Castano"
  description="Explore a selection of projects where design meets code and strategy to create meaningful digital experiences."
  canonical="https://asiacastano.com/project/"
>

const filters = [
  { label: "All", value: "all" },
  { label: "UX/UI Design", value: "ux-ui" },
  { label: "Web Development", value: "web-dev" },
  { label: "Digital / Strategy", value: "digital" },
];
---

<Layout title="Projects" navVariant="dark">
  <section class= "reveal-section mx-auto max-w-7xl px-6 pb-12 pt-28 md:px-12 md:pb-16 md:pt-36">
    <div class="grid gap-10 md:grid-cols-[1.2fr_0.8fr] md:items-end">
      <div>
        <h1 class="font-title text-[52px] leading-[0.9] tracking-[0.02em] text-[#113857] md:text-[90px]">
  SELECTED
  <span class="font-hand normal-case text-[58px] md:text-[110px] inline-block">
    projects
  </span>
</h1>
      </div>

      <div>
        <p class="max-w-xl text-sm leading-7 text-[#4a4a4a] md:text-base md:leading-8">
          A selection of projects across UX/UI design, web development and
          digital thinking. 
        </p>
      </div>
    </div>

    <div class="mt-12 flex flex-wrap gap-3">
  {filters.map((filter, index) => (
    <button
      type="button"
      data-filter-button
      data-filter={filter.value}
      class:list={[
        "rounded-full border px-4 py-2 text-sm transition duration-300",
        index === 0
          ? "border-[#113857] bg-[#113857] text-white hover:border-[#113857] hover:bg-[#113857] hover:text-white"
          : "border-[#113857]/20 bg-white/50 text-[#113857] hover:border-[#113857]/20 hover:bg-white hover:text-[#113857]",
      ]}
    >
      {filter.label}
    </button>
  ))}
</div>

  </section>




  <section class="reveal-section mx-auto max-w-7xl px-6 pb-16 md:px-12 md:pb-24">
  <div class="projects-intro">
  <p>
  Additional projects will be added soon.
  </p>
</div>
    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          data-project-card
          data-category={project.category}
          class="group relative overflow-hidden rounded-[2rem] bg-white shadow-[0_14px_35px_rgba(0,0,0,0.08)] transition duration-300 hover:-translate-y-1"
        >
          <div class="relative h-[320px] overflow-hidden md:h-[360px]">
            <img
              src={project.image}
              alt={project.title}
              class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
            />

            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent transition duration-300 group-hover:from-black/80 group-hover:via-black/28"></div>

            <div class="absolute inset-x-0 bottom-0 z-10 p-6">
              <h3 class="font-title text-[34px] leading-[0.92] tracking-[0.02em] text-white md:text-[42px]">
                {project.title}
                </h3>

              <div class="mt-3 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="rounded-full border border-white/20 bg-white/12 px-3 py-1 text-[11px] font-medium text-white/95 backdrop-blur-sm md:text-[12px]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <div class="px-6 pb-6 pt-5">
            <p class="max-w-xl text-sm leading-7 text-[#4a4a4a] md:text-base md:leading-8">
              {project.excerpt}
            </p>

            <div class="mt-5 inline-flex items-center text-sm font-medium text-[#113857]">
              <span>View case study</span>
              <span class="ml-2 transition-transform duration-300 group-hover:translate-x-1">
                →
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Footer />

  <script>
    const buttons = document.querySelectorAll("[data-filter-button]");
    const cards = document.querySelectorAll("[data-project-card]");

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.dataset.filter;

        buttons.forEach((btn) => {
          btn.classList.remove("border-[#113857]", "bg-[#113857]", "text-white");
          btn.classList.add("border-[#113857]/20", "bg-white/50", "text-[#113857]");
        });

        button.classList.remove("border-[#113857]/20", "bg-white/50", "text-[#113857]");
        button.classList.add("border-[#113857]", "bg-[#113857]", "text-white");

        cards.forEach((card) => {
          const category = card.dataset.category;
          const show = filter === "all" || category === filter;
          card.style.display = show ? "" : "none";
        });
      });
    });


    
  </script>


  <script>
  const revealSections = document.querySelectorAll(".reveal-section");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    },
    {
      threshold: 0.15,
    }
  );

  revealSections.forEach((section) => {
    observer.observe(section);
  });
</script>

</Layout>




