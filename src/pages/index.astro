---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";




<Layout
  title="Asia Castano – Portfolio"
  description="UX/UI designer, front-end developer and digital marketer. I design digital products combining design, code and strategy to create effective user experiences."
  canonical="https://asiacastano.com/"
>



const contributionItems = [
  {
  number: "01",
  title: "Digital marketing",
  preview: "Shaping how products and brands communicate in digital environments.",
  details: [
  "Defining content strategy and editorial direction",
  "Creating content across social media and digital channels",
  "Writing clear and effective website and landing page copy",
  "Optimizing content for search and visibility (SEO)",
  "Structuring and managing paid campaigns",
  "Designing email communication and automation flows",
],
  color: "text-[#7f97b2]",
},
  {
    number: "02",
    title: "UX/UI design",
    preview: "Designing intuitive digital experiences that make information easy to navigate.",
   details: [
  "User and market research to frame problems and opportunities",
  "Structuring experiences through information architecture and flows",
  "Exploring solutions with wireframes and prototypes",
  "Designing clear and consistent visual systems",
  "Testing and refining through usability evaluation",
  "Building accessible, user-centered interfaces (WCAG principles)",
],
    color: "text-[#7f97b2]",
  },
  {
    number: "03",
    title: "Web development",
    preview: "Turning ideas and designs into functional digital experiences.",
    details: [
  "Turning design into functional front-end code",
  "Building responsive websites",
  "Working with CMS platforms to manage content and structure",
  "Creating reusable components and scalable layouts",
  "Improving performance and usability",
  "Using AI and vibe coding to accelerate development workflows",
],
    color: "text-[#7f97b2]",
  },
];


const projects = [
  {
    title: "Brio",
    image: "/images/brio8.png",
    href: "/projects/brio",
    tags: ["UX/UI Design", "User Research"],
    height: "large",
  },
  {
    title: "My Bookcase",
    image: "/images/mybookcase1.png",
    href: "/projects/mybookcase",
    tags: ["Web Development", "Vibe Coding", "AI"],
    height: "small",
  },
  {
    title: "Wise Hands",
    image: "/images/wisehands7.png",
    href: "/projects/wisehands",
    tags: ["UX/UI Design", "User Research"],
    height: "small",
  },
  {
    title: "Noisy - Creative Agency",
    image: "/images/noisy1.png",
    href: "/projects/noisy",
    tags: ["Front-end Development"],
    height: "large",
  },
];


const tools = [
  {
    title: "AI <span class='font-hand normal-case'>&</span> Emerging Tools",
    text: "I explore how new technologies influence the way we design and build products, focusing on their impact on workflows, decision-making and user experience.",
  },
  {
    title: "Video",
    text: "Video is becoming one of the most powerful ways to communicate. I explore it as a language - where timing, rhythm and editing are not just aesthetic choices, but tools to guide attention and meaning.",
  },
  {
    title: "Photography",
    text: "Photography is where I train my eye. It’s about learning to notice what others might overlook — composition, light, balance — and bringing that awareness into design.",
  },
  {
    title: "Drone <span class='font-hand normal-case'>&</span> Aerial Video",
    text: "Seeing things from above offers a completely different perspective. Through aerial photography and video, I explore scale, composition and new ways of looking at familiar environments.",
  },
];
---

<Layout title="Home">
  
  
  
  <!-- HERO -->
  <section class="relative min-h-screen overflow-hidden">
    <img
      src="/images/hero.png"
      alt="Portrait background"
      class="absolute inset-0 h-full w-full object-cover"
    />

    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(7,36,63,0.58)_0%,rgba(9,49,82,0.38)_38%,rgba(102,142,170,0.18)_68%,rgba(210,227,235,0.08)_100%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.14)_0%,rgba(0,0,0,0.10)_35%,rgba(0,0,0,0.22)_100%)]"></div>

    <div class="relative z-10 mx-auto flex min-h-screen max-w-7xl items-end px-6 pb-12 pt-28 md:px-12 md:pb-20 md:pt-32">
      <div class="grid w-full gap-10 md:grid-cols-[1.05fr_0.95fr] md:items-end">
        <div>
          <h1 class="font-title animate-fade-up max-w-[520px] text-[48px] leading-[0.92] tracking-[0.02em] text-white md:text-[85px]">
            COMBINING DIGITAL
            <br />
            STRATEGY, DESIGN
            <br />
            <span class="font-hand text-[1.05em] align-middle">&</span>
            DEVELOPMENT
          </h1>
        </div>

        <div class="max-w-[420px] md:ml-auto md:pb-6">
          <p class="animate-fade-up animate-delay-1 text-base leading-[1.25] text-white/95 md:text-[1.15rem]">
            Three worlds that constantly rely on each other. Strategy gives direction,
            design shapes the experience, and development brings it to life.
          </p>

          <p class="animate-fade-up animate-delay-2 mt-5 text-[28px] leading-none text-white md:mt-6 md:text-[35px]">
            <span class="font-title align-middle tracking-[0.02em]">
              EXPLORING THE
            </span>
            <span class="font-hand ml-2 inline-block align-middle normal-case text-[0.95em]">
              whole picture.
            </span>
          </p>

          <a
  href="/projects"
  class="group animate-fade-up animate-delay-3 mt-6 inline-flex items-center justify-center rounded-full border border-white/30 bg-white/12 px-7 py-3 text-[1rem] font-medium text-white backdrop-blur-md shadow-[0_8px_24px_rgba(0,0,0,0.16)] transition duration-300 hover:-translate-y-0.5 hover:bg-white/18 hover:shadow-[0_12px_30px_rgba(0,0,0,0.2)] md:mt-7 md:min-w-[170px] md:px-8 md:py-3.5 md:text-[1.05rem]"
>
  <span>My projects</span>
  <span class="ml-2 transition-transform duration-300 group-hover:translate-x-1">
    →
  </span>
</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PATH -->
  <section class= "reveal-section mx-auto max-w-7xl px-6 py-16 md:px-12 md:py-24">
    <div class="grid gap-14 md:grid-cols-[0.95fr_1.05fr] md:gap-24 lg:gap-32">
      <div> 
        <h2 class="font-title text-[40px] leading-[0.92] tracking-[0.02em] md:text-[65px]">
          MY PATH INTO THE
          <span class="font-hand normal-case text-[1.05em]">digital world</span>
          <br />
          HAS NEVER FOLLOWED
          <br />
          A SINGLE DIRECTION
        </h2>
      </div>

      <div class="max-w-[640px] space-y-6 text-sm leading-7 text-[#3c3c3c] md:text-lg md:leading-8">
        <p>
          My background sits between <strong>digital marketing</strong>,
          <strong>UX/UI design</strong> and <strong>web development</strong>,
          different disciplines, but closely connected when it comes to building
          <strong>meaningful digital experiences</strong>.
        </p>

        <p>
          Working across these areas allows me to approach
          <strong>digital products</strong> from multiple perspectives:
          the idea behind them, the experience they create for users,
          the <strong>technical structure</strong> that makes them work,
          and the <strong>strategy</strong> that helps them succeed.
        </p>
      </div>
    </div>
  </section>





  <!-- CONTRIBUTION -->
  <section class="reveal-section mx-auto max-w-7xl border-t border-[#e5e5e0] px-6 py-16 md:px-12 md:py-24">
    <div class="grid gap-14 md:grid-cols-[0.95fr_1.05fr] md:gap-24 lg:gap-32">
      <div class="md:pr-6">
        <h2 class="font-title text-[40px] leading-[0.92] tracking-[0.02em] md:text-[65px]">
          HOW I CONTRIBUTE TO
          <br />
          <span class="font-hand normal-case text-[1.05em]">
            digital projects
          </span>
        </h2>
      </div>

      <div class="space-y-10 md:space-y-12">
  {contributionItems.map((item) => (
    <details class="group border-b border-[#dfdfd8] pb-8 last:border-b-0">
      <summary class="list-none cursor-pointer">
        <div class="grid gap-4 md:grid-cols-[90px_1fr_auto] md:gap-8">
          <div class={`font-hand text-[32px] leading-none ${item.color} md:text-[38px]`}>
            {item.number}
          </div>

          <div>
            <h3 class="font-title text-[30px] leading-[0.95] tracking-[0.02em] text-[#113857] md:text-[42px]">
  {item.title}
</h3>

            <p class="mt-3 max-w-2xl text-sm leading-[1.5] text-[#474747] md:text-base">
  {item.preview}
</p>
          </div>

          <div class="flex items-end justify-end">
  <span class="text-[34px] leading-none text-[#113857] transition duration-300 group-open:rotate-90">
    +
  </span>
</div>
        </div>
      </summary>

      <div class="mt-5 md:grid md:grid-cols-[90px_1fr_auto] md:gap-8">
  <div></div>

  <div class="accordion-reveal max-w-2xl">
    <ul class="space-y-2 text-sm leading-7 text-[#1f1f1f] md:text-base md:leading-8">
      {item.details.map((detail) => (
        <li>• {detail}</li>
      ))}
    </ul>
  </div>

  <div></div>
</div>
    </details>
  ))}
</div>
    </div>
  </section>





  <!-- TOOLS -->
    <!-- TOOLS -->
  <section class="reveal-section bg-[#f1f1ee]">
    <div class="mx-auto max-w-7xl px-6 py-16 md:px-12 md:py-24">
      <div class="grid gap-16 md:grid-cols-[1fr_1fr] md:gap-32 lg:gap-40">
        <div class="md:pr-4">
          <h2 class="max-w-[520px] font-title text-[40px] leading-[0.92] tracking-[0.02em] md:text-[65px]">
  ALWAYS
  <span class="font-hand normal-case text-[48px] md:text-[75px]">
  exploring
</span>
  NEW TOOLS AND TECHNOLOGIES
</h2>

          <p class="mt-5 max-w-[460px] text-sm leading-[1] text-[#4a4a4a] md:text-base md:leading-[1.5]">
            I don’t stick to one medium or way of working. I explore, test and question, keeping creativity and experimentation part of the process.
          </p>

          <div class="mt-12 space-y-8 md:space-y-10">
            {tools.map((tool) => (
              <div>
                <h3
  					class="font-title text-[28px] leading-[0.95] tracking-[0.02em] text-[#113857] md:text-[36px]"
  					set:html={tool.title}
				/>
                <p class="mt-2 max-w-xl text-sm leading-[1.5] text-[#4a4a4a] md:text-base md:leading-[1.45]">
  					{tool.text}
				</p>
              </div>
            ))}
          </div>
        </div>

        <div class="grid grid-cols-2 gap-5 md:gap-7 self-start place-self-center">
  <div class="overflow-hidden rounded-[1.9rem] shadow-[0_10px_30px_rgba(0,0,0,0.08)] md:translate-y-2">
    <img src="/images/tool-1.png" alt="Landscape"
      class="block h-[240px] w-full object-cover transition duration-500 hover:scale-105 md:h-[420px]"/>
  </div>

  <div class="overflow-hidden rounded-[1.9rem] shadow-[0_10px_30px_rgba(0,0,0,0.08)] md:translate-y-12">
    <img src="/images/tool-4.jpg" alt="Landscape"
      class="block h-[240px] w-full object-cover transition duration-500 hover:scale-105 md:h-[420px]"/>
  </div>

  <div class="overflow-hidden rounded-[1.9rem] shadow-[0_10px_30px_rgba(0,0,0,0.08)] md:-translate-y-2">
    <img src="/images/tool-3.png" alt="Portrait"
      class="block h-[240px] w-full object-cover transition duration-500 hover:scale-105 md:h-[420px]"/>
  </div>

  <div class="overflow-hidden rounded-[1.9rem] shadow-[0_10px_30px_rgba(0,0,0,0.08)] md:translate-y-8">
    <img src="/images/tool-2.png" alt="Landscape"
      class="block h-[240px] w-full object-cover transition duration-500 hover:scale-105 md:h-[420px]"/>
  </div>
</div>
  </section>




  <!-- PROJECTS -->
  <section class="reveal-section mx-auto max-w-7xl px-6 py-14 md:px-12 md:py-20">
   <h2 class="font-title text-[40px] leading-[0.92] tracking-[0.02em] md:text-[65px]">
  SELECTED
  <span class="font-hand normal-case text-[48px] md:text-[75px] inline-block">
    projects
  </span>
</h2>

    <a
  href="/projects"
  class="group mt-6 inline-flex items-center justify-center rounded-full border border-[#113857]/20 bg-white/40 px-7 py-3 text-[1rem] font-medium text-[#113857] backdrop-blur-md shadow-[0_8px_24px_rgba(0,0,0,0.08)] transition duration-300 hover:-translate-y-0.5 hover:bg-white/60 hover:shadow-[0_12px_30px_rgba(0,0,0,0.12)] md:mt-7 md:min-w-[190px] md:px-8 md:py-3.5 md:text-[1.05rem]"
>
  <span>View all projects</span>
  <span class="ml-2 transition-transform duration-300 group-hover:translate-x-1">
    →
  </span>
</a>

    <div class="mt-12 grid gap-5 md:grid-cols-12 md:auto-rows-[180px]">
  
  
  <!-- Card grande -->
  <a
    href={projects[0].href}
    class="group relative overflow-hidden rounded-[2rem] shadow-[0_14px_35px_rgba(0,0,0,0.08)] md:col-span-7 md:row-span-2 min-h-[320px] md:min-h-0"
  >
    <img
      src={projects[0].image}
      alt={projects[0].title}
      class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />

    <div class="absolute inset-0 bg-gradient-to-t from-black/72 via-black/20 to-transparent transition duration-300 group-hover:from-black/80 group-hover:via-black/28"></div>

    <div class="absolute inset-x-0 bottom-0 z-10 p-6 md:p-7">
      <h3 class="font-title text-[30px] leading-[0.95] tracking-[0.02em] text-white md:text-[40px]">
        {projects[0].title}
      </h3>

      <div class="mt-3 flex flex-wrap gap-2">
        {projects[0].tags.map((tag) => (
          <span class="rounded-full border border-white/20 bg-white/12 px-3 py-1 text-[11px] font-medium text-white/95 backdrop-blur-sm md:text-[12px]">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </a>



  <!-- Card verticale -->
  <a
    href={projects[1].href}
    class="group relative overflow-hidden rounded-[2rem] shadow-[0_14px_35px_rgba(0,0,0,0.08)] md:col-span-5 md:row-span-2 min-h-[320px] md:min-h-0"
  >
    <img
      src={projects[1].image}
      alt={projects[1].title}
      class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />

    <div class="absolute inset-0 bg-gradient-to-t from-black/72 via-black/20 to-transparent transition duration-300 group-hover:from-black/80 group-hover:via-black/28"></div>

    <div class="absolute inset-x-0 bottom-0 z-10 p-6">
      <h3 class="font-title text-[26px] leading-[0.95] tracking-[0.02em] text-white md:text-[34px]">
        {projects[1].title}
      </h3>

      <div class="mt-3 flex flex-wrap gap-2">
        {projects[1].tags.map((tag) => (
          <span class="rounded-full border border-white/20 bg-white/12 px-3 py-1 text-[10px] font-medium text-white/95 backdrop-blur-sm md:text-[11px]">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </a>

  <!-- Card orizzontale -->
  <a
    href={projects[2].href}
    class="group relative overflow-hidden rounded-[2rem] shadow-[0_14px_35px_rgba(0,0,0,0.08)] md:col-span-8 md:row-span-1 min-h-[220px] md:min-h-0"
  >
    <img
      src={projects[2].image}
      alt={projects[2].title}
      class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />

    <div class="absolute inset-0 bg-gradient-to-t from-black/72 via-black/20 to-transparent transition duration-300 group-hover:from-black/80 group-hover:via-black/28"></div>

    <div class="absolute inset-x-0 bottom-0 z-10 p-5 md:p-6">
      <h3 class="font-title text-[24px] leading-[0.95] tracking-[0.02em] text-white md:text-[32px]">
        {projects[2].title}
      </h3>

      <div class="mt-2 flex flex-wrap gap-2">
        {projects[2].tags.map((tag) => (
          <span class="rounded-full border border-white/20 bg-white/12 px-3 py-1 text-[10px] font-medium text-white/95 backdrop-blur-sm md:text-[11px]">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </a>

  <!-- Card piccola -->
  <a
    href={projects[3].href}
    class="group relative overflow-hidden rounded-[2rem] shadow-[0_14px_35px_rgba(0,0,0,0.08)] md:col-span-4 md:row-span-1 min-h-[220px] md:min-h-0"
  >
    <img
      src={projects[3].image}
      alt={projects[3].title}
      class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />

    <div class="absolute inset-0 bg-gradient-to-t from-black/72 via-black/20 to-transparent transition duration-300 group-hover:from-black/80 group-hover:via-black/28"></div>

    <div class="absolute inset-x-0 bottom-0 z-10 p-5 md:p-6">
      <h3 class="font-title text-[24px] leading-[0.95] tracking-[0.02em] text-white md:text-[30px]">
        {projects[3].title}
      </h3>

      <div class="mt-2 flex flex-wrap gap-2">
        {projects[3].tags.map((tag) => (
          <span class="rounded-full border border-white/20 bg-white/12 px-3 py-1 text-[10px] font-medium text-white/95 backdrop-blur-sm md:text-[11px]">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </a>
</div>
  </section>








  <!-- FINAL BAND -->
  

  <Footer/>
</Layout>

<script>
  const revealSections = document.querySelectorAll(".reveal-section");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    },
    {
      threshold: 0.15,
    }
  );

  revealSections.forEach((section) => {
    observer.observe(section);
  });
</script>